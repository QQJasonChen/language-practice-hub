  },
  {
    "start": 724.0,
    "end": 726.0,
    "text": "じゃあまずは一番目を引く",
    "translation": "那麼首先來試試最吸引眼球的"
  },
  {
    "start": 726.0,
    "end": 728.0,
    "text": "インダラキョウカス漬け",
    "translation": "印達拉強化醋漬"
  },
  {
    "start": 728.0,
    "end": 730.0,
    "text": "いただきます",
    "translation": "開動了"
  },
  {
    "start": 730.0,
    "end": 732.0,
    "text": "すごい重量感",
    "translation": "重量感十足"
  },
  {
    "start": 732.0,
    "end": 734.0,
    "text": "肉厚感も伝わるかな",
    "translation": "肉質的厚實感也能感受到"
  },
  {
    "start": 738.0,
    "end": 740.0,
    "text": "めちゃくちゃ柔らかい",
    "translation": "非常柔軟"
  },
  {
    "start": 740.0,
    "end": 742.0,
    "text": "すごい油がのってて甘みがある",
    "translation": "油脂豐富且帶有甜味"
  },
  {
    "start": 746.0,
    "end": 748.0,
    "text": "牛肉たけのこ",
    "translation": "牛肉筍"
  },
  {
    "start": 750.0,
    "end": 752.0,
    "text": "たけのこのサクサクとした食感と",
    "translation": "筍的脆脆口感和"
  },
  {
    "start": 752.0,
    "end": 754.0,
    "text": "鰹節風味の牛肉そぼろの組み合わせが絶妙",
    "translation": "鰹魚風味的牛肉碎的組合非常絶妙"
  },
  {
    "start": 758.0,
    "end": 760.0,
    "text": "綺麗に焼かれた卵焼き",
    "translation": "精緻地烤好的蛋捲"
  },
  {
    "start": 764.0,
