    "end": 682.6000061035156,
    "text": "東京の老舗の味を詰め込んだ豪華駅弁です",
    "translation": "裝滿東京老字號的味道的豪華便當"
  },
  {
    "start": 682.6000061035156,
    "end": 685.5599975585938,
    "text": "重箱風の立派な弁当箱を開けると",
    "translation": "打開像重箱一樣的華麗便當盒"
  },
  {
    "start": 685.5599975585938,
    "end": 694.3200073242188,
    "text": "中には色とりどりのおかずがぎっしり詰まっています",
    "translation": "裡面塞滿了色彩繽紛的小菜"
  },
  {
    "start": 694.3200073242188,
    "end": 697.7200012207031,
    "text": "贅沢品としても定番の浅草芋飯や",
    "translation": "作為奢侈品的經典淺草芋飯"
  },
  {
    "start": 697.7200012207031,
    "end": 700.3200073242188,
    "text": "人形蝶うごきゅうの強化酢漬け",
    "translation": "人形蝶動的強化醋漬"
  },
  {
    "start": 700.3200073242188,
    "end": 702.4800109863281,
    "text": "寿司玉あおきの卵焼きなど",
    "translation": "壽司玉青木的蛋捲等等"
  },
  {
    "start": 702.4800109863281,
    "end": 705.2000122070312,
    "text": "東京を代表する老舗八点の味を",
    "translation": "將東京代表性的老字號八點的味道"
  },
  {
    "start": 705.2000122070312,
    "end": 712.0400085449219,
    "text": "一箱に凝縮しています",
    "translation": "濃縮在一盒裡"
  },
  {
    "start": 712.0400085449219,
    "end": 714.6000061035156,
    "text": "これまず見た目が華やかでいいよね",
    "translation": "這個首先外觀就很華麗，真不錯"
  },
  {
    "start": 714.6000061035156,
    "end": 718.8399963378906,
    "text": "お魚とか煮物とか体にいい食材が詰まってる感じ",
    "translation": "裡面有魚類、煮物等對身體好的食材"
  },
  {
    "start": 718.8399963378906,
    "end": 720.0,
    "text": "ちゃんとね丁寧に",
    "translation": "認真且細心地"
  },
  {
    "start": 720.0,
    "end": 722.0,
    "text": "お品書きも入ってました",
    "translation": "還有菜單"
  },
  {
    "start": 722.0,
    "end": 724.0,
    "text": "旅館の食事みたい",
