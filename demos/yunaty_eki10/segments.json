    "text": "ぴったりの満足度の高い駅弁です",
    "translation": "非常適合的高滿意度車站便當"
  },
  {
    "start": 796.0,
    "end": 798.0,
    "text": "第2位 チキン弁当",
    "translation": "第2名 雞肉便當"
  },
  {
    "start": 800.0,
    "end": 802.0,
    "text": "1964年の東海道新幹線開業とともに登場した",
    "translation": "隨著1964年東海道新幹線的開業而登場"
  },
  {
    "start": 802.0,
    "end": 804.0,
    "text": "駅弁の代名詞ともいえる",
    "translation": "可說是車站便當的代名詞"
  },
  {
    "start": 804.0,
    "end": 806.0,
    "text": "ロングセラー商品です",
    "translation": "長期暢銷商品"
  },
  {
    "start": 806.0,
    "end": 808.0,
    "text": "懐かしさを感じさせるパッケージデザインと",
    "translation": "讓人感到懷舊的包裝設計"
  },
  {
    "start": 808.0,
    "end": 810.0,
    "text": "愛らしいキャラクターのイラストが印象的で",
    "translation": "可愛角色的插圖令人印象深刻"
  },
  {
    "start": 810.0,
    "end": 812.0,
    "text": "取っ手を立てれば",
    "translation": "把手把立起來"
  },
  {
    "start": 812.0,
    "end": 814.0,
    "text": "チキンバスケット風の形に早変わり",
    "translation": "迅速變成雞肉籃的形狀"
  },
  {
    "start": 816.0,
