        {
          "t": "12:06",
          "s": 726.0,
          "ja": "インダラキョウカス漬け",
          "zh": "印達拉強化醋漬"
        },
        {
          "t": "12:08",
          "s": 728.0,
          "ja": "いただきます",
          "zh": "開動了"
        },
        {
          "t": "12:10",
          "s": 730.0,
          "ja": "すごい重量感",
          "zh": "重量感十足"
        },
        {
          "t": "12:12",
          "s": 732.0,
          "ja": "肉厚感も伝わるかな",
          "zh": "肉質的厚實感也能感受到"
        },
        {
          "t": "12:18",
          "s": 738.0,
          "ja": "めちゃくちゃ柔らかい",
          "zh": "非常柔軟"
        },
        {
          "t": "12:20",
          "s": 740.0,
          "ja": "すごい油がのってて甘みがある",
          "zh": "油脂豐富且帶有甜味"
        },
        {
          "t": "12:26",
          "s": 746.0,
          "ja": "牛肉たけのこ",
          "zh": "牛肉筍"
        },
        {
          "t": "12:30",
          "s": 750.0,
          "ja": "たけのこのサクサクとした食感と",
          "zh": "筍的脆脆口感和"
        },
        {
          "t": "12:32",
          "s": 752.0,
          "ja": "鰹節風味の牛肉そぼろの組み合わせが絶妙",
          "zh": "鰹魚風味的牛肉碎的組合非常絶妙"
        },
        {
          "t": "12:38",
          "s": 758.0,
          "ja": "綺麗に焼かれた卵焼き",
          "zh": "精緻地烤好的蛋捲"
        },
        {
          "t": "12:44",
          "s": 764.0,
          "ja": "卵焼きは甘めの味付け",
          "zh": "蛋捲的味道偏甜"
        },
        {
          "t": "12:46",
          "s": 766.0,
          "ja": "煮物いただきます",
          "zh": "來試試煮物"
        },
        {
          "t": "12:52",
          "s": 772.0,
          "ja": "全体的にしっかり濃いめの味付けで",
          "zh": "整體味道偏濃厚"
        },
        {
          "t": "12:54",
          "s": 774.0,
          "ja": "冷めても美味しく食べられる感じ",
          "zh": "即使冷卻也能美味地享用"
        },
        {
          "t": "13:00",
          "s": 780.0,
          "ja": "しな数が豊富で",
          "zh": "食品種類豐富"
        },
        {
          "t": "13:02",
          "s": 782.0,
          "ja": "様々な味を少しずつ楽しみたい人に",
          "zh": "想要享受各種口味的人"
        },
        {
          "t": "13:04",
          "s": 784.0,
          "ja": "ぴったりの満足度の高い駅弁です",
          "zh": "非常適合的高滿意度車站便當"
        }
      ]
    },
