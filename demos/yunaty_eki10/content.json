      "culture": "日本「焼肉」概念來自戰後韓國燒肉店，現已本地化為日本獨立菜系；和「すき焼き（涮鍋＋醬油糖風）」是兩種完全不同的家庭吃法。",
      "start_t": "9:38",
      "end_t": "11:07",
      "n_lines": 22,
      "dialogue": [
        {
          "t": "9:40",
          "s": 580.28,
          "ja": "第4位 牛すきと牛焼肉弁当",
          "zh": "第4名 牛肉燒和牛肉燒肉便當"
        },
        {
          "t": "9:44",
          "s": 584.32,
          "ja": "すき焼きと焼肉",
          "zh": "燒肉和燒肉"
        },
        {
          "t": "9:45",
          "s": 585.76,
          "ja": "異なる味付けの牛肉を一度に楽しめる",
          "zh": "可以一次享受不同調味的牛肉"
        },
        {
          "t": "9:48",
          "s": 588.76,
          "ja": "肉好きにはたまらない駅弁です",
          "zh": "對肉食愛好者來說簡直無法抗拒的便當"
        },
        {
          "t": "9:55",
          "s": 595.2,
          "ja": "焼肉側には香ばしく網焼きされた牛カルビが並び",
          "zh": "燒肉那邊擺著香氣四溢的烤牛肋排"
        },
        {
          "t": "9:59",
          "s": 599.04,
          "ja": "もやしナムルがアクセントに",
          "zh": "豆芽拌菜成為了點綴"
        },
        {
          "t": "10:02",
          "s": 602.12,
          "ja": "副菜を挟んで反対側のすき焼きには",
          "zh": "副菜之間的對面是燒肉"
        },
        {
          "t": "10:05",
          "s": 605.12,
          "ja": "甘辛く煮込まれた牛肉に",
          "zh": "醬汁甘甜的燉牛肉"
        },
        {
          "t": "10:07",
          "s": 607.2,
          "ja": "しらたきや椎茸が添えられ",
          "zh": "還搭配了白滷和香菇"
        },
        {
          "t": "10:09",
          "s": 609.2,
          "ja": "ご飯との相性は言うまでもありません",
          "zh": "與米飯的相性不言而喻"
        },
        {
          "t": "10:13",
          "s": 613.64,
          "ja": "中央には煮卵と小松菜のナムルが添えられ",
          "zh": "中央擺著煮蛋和小松菜拌菜"
        },
        {
          "t": "10:17",
          "s": 617.08,
          "ja": "彩り栄養バランスの両面からも優れた構成になっています",
          "zh": "從色彩和營養平衡兩方面來看都是優秀的組合"
        },
        {
          "t": "10:24",
          "s": 624.56,
          "ja": "じゃあまずは焼肉からいただきます",
          "zh": "那麼首先來品嚐燒肉"
        },
        {
          "t": "10:31",
          "s": 631.44,
          "ja": "焼肉はタレの風味が濃くてガッツリとした味わい",
          "zh": "燒肉的醬汁風味濃郁，口感十足"
        },
        {
          "t": "10:35",
          "s": 635.2,
          "ja": "ご飯が進む",
          "zh": "讓米飯更容易下飯"
        },
        {
          "t": "10:37",
          "s": 637.36,
          "ja": "すき焼きの方をいただきます",
          "zh": "接下來品嚐燒肉"
        },
        {
          "t": "10:43",
          "s": 643.76,
          "ja": "すき焼きはお肉にもしらたきにも",
          "zh": "燒肉的肉質和白滷都"
        },
        {
          "t": "10:46",
          "s": 646.0,
          "ja": "だしがよく染みてて",
          "zh": "吸收了高湯的味道"
        },
        {
          "t": "10:47",
          "s": 647.32,
          "ja": "お肉の食感と風味をしっかり感じられる",
          "zh": "可以清楚感受到肉的口感和風味"
        },
        {
          "t": "10:50",
          "s": 650.24,
          "ja": "小松菜ナムルは焼肉にもすき焼きにもよく合う",
          "zh": "小松菜拌菜無論是搭配燒肉還是燒肉都非常合適"
        },
        {
          "t": "10:59",
          "s": 659.72,
          "ja": "贅沢なお肉を交互に頬張る",
          "zh": "交替享用奢華的肉"
        },
        {
          "t": "11:02",
          "s": 662.0,
          "ja": "なんとも言えない幸せに包まれます",
          "zh": "被無法言喻的幸福包圍"
        }
      ]
    },
